package components

// IconHome renders the Lucide home icon.
templ IconHome(className string) {
	<svg xmlns="http://www.w3.org/2000/svg" class={ className } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
		<polyline points="9 22 9 12 15 12 15 22"/>
	</svg>
}

// IconPlusCircle renders the Lucide plus-circle icon.
templ IconPlusCircle(className string) {
	<svg xmlns="http://www.w3.org/2000/svg" class={ className } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<circle cx="12" cy="12" r="10"/>
		<path d="M8 12h8"/>
		<path d="M12 8v8"/>
	</svg>
}

