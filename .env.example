# Sadqa Ledger — environment configuration
# Copy this file to `.env` and fill in real values. Never commit your actual `.env` file.
# See docs/DEPLOY.md for a full walkthrough of where each of these values comes from.

# --- Server ---

# Port the app listens on inside its container. Caddy proxies HTTPS traffic to this port.
PORT=8080

# Public base URL of your deployment (used to build absolute links, e.g. in the WhatsApp summary).
# Must match the domain you point Caddy at.
BASE_URL=https://ledger.example.org

# --- Database ---

# Path to the SQLite database file. In Docker this should point inside a mounted volume
# so the data survives container restarts/upgrades.
DATABASE_PATH=/data/sadqa-ledger.db

# --- Sessions ---

# Long, random secret used to sign session-related values. Generate your own — do not reuse this example.
# You can generate one with: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-long-random-string

# How many days an admin stays logged in before needing to log in again.
SESSION_LIFETIME_DAYS=30

# --- Litestream / Cloudflare R2 backups ---
# All four of these are required for continuous backup. See docs/DEPLOY.md for how to
# create a free Cloudflare R2 bucket and API token.

LITESTREAM_R2_BUCKET=your-r2-bucket-name
LITESTREAM_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
LITESTREAM_R2_ACCESS_KEY_ID=your-r2-access-key-id
LITESTREAM_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# --- Default currency ---
# Used only the first time the app runs (first-run setup wizard); afterward it's stored
# in the database and changed from the in-app Settings screen.

DEFAULT_CURRENCY_CODE=INR
DEFAULT_CURRENCY_SYMBOL=₹

# --- Default language ---
# Language shown on the public transparency page before any admin changes it in Settings.
# One of: en, hi, ar

DEFAULT_PUBLIC_LANGUAGE=en

# --- Logging ---

# One of: debug, info, warn, error
LOG_LEVEL=info
